"""
End-to-end PHS build flow for the streamer_phs_alu kernel on schnitzel.

  phsc (MLIR → SV + SoC verilog) → verilator (sim binary)
                                  → clang (test ELF)
                                  → simulate & verify

Usage: pixi run -e phs snakemake -j$(nproc)
"""
import os

ROOT = os.path.abspath("../..")
BUILD = "build"
GENERATED = os.path.abspath(f"{BUILD}/generated")
SIM_BUILD = f"{BUILD}/sim"
DEVICE_BUILD = f"{BUILD}/device"

rule all:
    input:
        f"{BUILD}/test.log",


# --- Step 1: PHS compilation + schnitzel hardware generation ---
# phsc compiles MLIR → BlackBox SV, then calls PhsDriver via mill
# to generate the full SoC verilog in one step.

rule phsc:
    input:
        mlir="addition.mlir",
        schedule="transform_schedule.mlir",
        software="test_software.mlir",
    output:
        top=f"{GENERATED}/Top.sv",
        filelist=f"{GENERATED}/filelist.f",
    shell:
        """
        phsc {input.mlir} {input.schedule} \
            --software-file {input.software} \
            -o {BUILD}/sw.mlir \
            --output-hardware {ROOT}/src/main/resources/phs/acc1_array.sv \
            --output-schnitzel-dir {GENERATED}
        """


# --- Step 2: Build simulator (Verilator) ---

rule configure_sim:
    input:
        filelist=f"{GENERATED}/filelist.f",
    output:
        ninja=f"{SIM_BUILD}/build.ninja",
    shell:
        "cmake -B {SIM_BUILD} -S {ROOT}/sim -G Ninja -DGENERATED_DIR={GENERATED}"

rule build_sim:
    input:
        ninja=f"{SIM_BUILD}/build.ninja",
        top=f"{GENERATED}/Top.sv",
    output:
        sim=f"{SIM_BUILD}/sim",
    threads: workflow.cores
    shell:
        "cmake --build {SIM_BUILD} -j{threads}"


# --- Step 3: Build test software ---

rule configure_device:
    output:
        ninja=f"{DEVICE_BUILD}/build.ninja",
    shell:
        "cmake -B {DEVICE_BUILD} -S {ROOT}/sw/device -G Ninja"

rule build_device:
    input:
        ninja=f"{DEVICE_BUILD}/build.ninja",
    output:
        elf=f"{DEVICE_BUILD}/apps/alu_accelerator_test.elf",
    shell:
        "cmake --build {DEVICE_BUILD}"


# --- Step 4: Simulate ---

rule simulate:
    input:
        sim=f"{SIM_BUILD}/sim",
        elf=f"{DEVICE_BUILD}/apps/alu_accelerator_test.elf",
    output:
        log=f"{BUILD}/test.log",
    shell:
        """
        {input.sim} {input.elf} --vltargs="+ibex_tracer_enable=0" 2>&1 | tee {output.log}
        grep -q "TEST PASSED" {output.log}
        """
