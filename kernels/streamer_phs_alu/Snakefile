"""
End-to-end PHS build flow for the streamer_phs_alu kernel on schnitzel.

  phsc (MLIR → SV + SoC verilog + sw.llvm.mlir)
    → mlir-translate (sw.ll)
    → clang (sw.o)
    → link with runtime → test.elf
    → verilator sim → simulate

Usage: pixi run -e phs snakemake -j$(nproc)
"""

import os

ROOT = os.path.abspath("../..")
BUILD = "build"
SIM_BUILD = f"{BUILD}/sim"
DEVICE_BUILD = f"{BUILD}/device"

# Cross-compilation settings (must match ibex-toolchain.cmake)
CXX = "clang++"
CC = "clang"
CFLAGS = (
    "-O2 --target=riscv32-unkown-elf -march=rv32imc -mabi=ilp32 -fno-builtin-printf"
)
LDFLAGS = f"{CFLAGS} -fuse-ld=lld -nostartfiles -nostdlib"
RUNTIME_INCLUDE = f"{ROOT}/sw/device/runtime"
MLIR_INCLUDE = f"{ROOT}/sw/common/mlir"
LINKER_SCRIPT = f"{RUNTIME_INCLUDE}/link.ld"

# Array bounds to test
ARRAY_BOUNDS = [1, 2, 4]


rule all:
    input:
        expand(f"{BUILD}/bounds_{{b}}/test.log", b=ARRAY_BOUNDS),


# --- Generate per-bounds transform schedule ---


rule generate_schedule:
    output:
        f"{BUILD}/bounds_{{b}}/transform_schedule.mlir",
    params:
        bounds=lambda wc: wc.b,
    shell:
        r"""
        cat > {output} << 'MLIR_EOF'
module @transforms attributes {{ transform.with_named_sequence }} {{
  transform.named_sequence @__transform_main(
      %root: !transform.any_op {{transform.readonly}}) {{
    %matmul = transform.collect_matching @match_generic in %root
      : (!transform.any_op) -> !transform.any_op
    transform.include @annotate_generic failures(propagate)  (%matmul)
      : (!transform.any_op) -> ()

    transform.yield
  }}

  transform.named_sequence @match_generic(
      %entry: !transform.any_op {{transform.readonly}}) -> !transform.any_op {{
    transform.match.operation_name %entry ["linalg.generic"] : !transform.any_op
    transform.match.structured %entry: !transform.any_op {{
     ^bb0(%c: !transform.any_op):
       %n_ins = transform.match.structured.num_inputs %c
         : (!transform.any_op) -> !transform.param<i64>
       %c2 = transform.param.constant 2 : i64 -> !transform.param<i64>
       transform.match.param.cmpi eq %n_ins, %c2 : !transform.param<i64>
    }}
    transform.yield %entry : !transform.any_op
  }}

  transform.named_sequence @annotate_generic(
     %matmul: !transform.any_op {{transform.readonly}}) {{
       %attr_value = transform.param.constant @acc1 -> !transform.any_param
       transform.annotate %matmul "phs_acc" = %attr_value : !transform.any_op, !transform.any_param
       %bounds = transform.param.constant dense<[{params.bounds}]> : vector<1xi64> -> !transform.any_param
       transform.annotate %matmul "phs_array_bounds" = %bounds : !transform.any_op, !transform.any_param
       transform.yield
  }}
}}
MLIR_EOF
        """


# --- Step 1: PHS compilation + schnitzel hardware generation ---


rule phsc:
    input:
        mlir="addition.mlir",
        schedule=f"{BUILD}/bounds_{{b}}/transform_schedule.mlir",
        software="test_software.mlir",
    output:
        sw=f"{BUILD}/bounds_{{b}}/sw.llvm.mlir",
        top=f"{BUILD}/bounds_{{b}}/generated/Top.sv",
        filelist=f"{BUILD}/bounds_{{b}}/generated/filelist.f",
    params:
        generated=lambda wc: os.path.abspath(f"{BUILD}/bounds_{wc.b}/generated"),
    shell:
        """
        phsc {input.mlir} {input.schedule} \
            --software-file {input.software} \
            -o {output.sw} \
            --output-hardware {params.generated}/acc1_array.sv \
            --output-schnitzel-dir {params.generated}
        """


# --- Step 2: Compile PHS software kernel ---


rule translate_mlir:
    input:
        f"{BUILD}/bounds_{{b}}/sw.llvm.mlir",
    output:
        f"{BUILD}/bounds_{{b}}/sw.ll",
    shell:
        "mlir-translate --mlir-to-llvmir -o {output} {input}"


rule compile_mlir_kernel:
    input:
        f"{BUILD}/bounds_{{b}}/sw.ll",
    output:
        f"{BUILD}/bounds_{{b}}/sw.o",
    shell:
        "{CC} {CFLAGS} -x ir -c {input} -o {output} -Wno-override-module"


# --- Step 3: Build device runtime (cmake, once) ---


rule configure_device:
    output:
        ninja=f"{DEVICE_BUILD}/build.ninja",
    shell:
        "cmake -B {DEVICE_BUILD} -S {ROOT}/sw/device -G Ninja"


rule build_device_runtime:
    input:
        ninja=f"{DEVICE_BUILD}/build.ninja",
    output:
        runtime=f"{DEVICE_BUILD}/runtime/libdevice_runtime.a",
    shell:
        "cmake --build {DEVICE_BUILD} --target device_runtime"


# --- Step 4: Compile and link test harness ---


rule compile_main:
    input:
        "main.cpp",
    output:
        f"{BUILD}/main.o",
    shell:
        "{CXX} {CFLAGS} -I{RUNTIME_INCLUDE} -I{MLIR_INCLUDE} -c {input} -o {output}"


rule link:
    input:
        sw=f"{BUILD}/bounds_{{b}}/sw.o",
        main=f"{BUILD}/main.o",
        runtime=f"{DEVICE_BUILD}/runtime/libdevice_runtime.a",
    output:
        f"{BUILD}/bounds_{{b}}/test.elf",
    shell:
        "{CC} {LDFLAGS} -T{LINKER_SCRIPT} {input.sw} {input.main} {input.runtime} -o {output}"


# --- Step 5: Build simulator (Verilator) ---


rule configure_sim:
    input:
        filelist=f"{BUILD}/bounds_{{b}}/generated/filelist.f",
    output:
        ninja=f"{BUILD}/bounds_{{b}}/sim/build.ninja",
    params:
        generated=lambda wc: os.path.abspath(f"{BUILD}/bounds_{wc.b}/generated"),
        sim_build=lambda wc: f"{BUILD}/bounds_{wc.b}/sim",
    shell:
        "cmake -B {params.sim_build} -S {ROOT}/sim -G Ninja -DGENERATED_DIR={params.generated}"


rule build_sim:
    input:
        ninja=f"{BUILD}/bounds_{{b}}/sim/build.ninja",
        top=f"{BUILD}/bounds_{{b}}/generated/Top.sv",
    output:
        sim=f"{BUILD}/bounds_{{b}}/sim/sim",
    threads: workflow.cores
    shell:
        "cmake --build {BUILD}/bounds_{wildcards.b}/sim -j{threads}"


# --- Step 6: Simulate ---


rule simulate:
    input:
        sim=f"{BUILD}/bounds_{{b}}/sim/sim",
        elf=f"{BUILD}/bounds_{{b}}/test.elf",
    output:
        log=f"{BUILD}/bounds_{{b}}/test.log",
    shell:
        """
        {input.sim} {input.elf} --vltargs="+ibex_tracer_enable=0" 2>&1 | tee {output.log}
        grep -q "TEST PASSED" {output.log}
        """
